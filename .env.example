# ==============================================================================
# FemTech Medical RAG Agent - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
ENVIRONMENT=development  # development, staging, production
DEBUG=false
APP_NAME="FemTech Medical RAG Agent"
APP_VERSION=0.1.0

# ------------------------------------------------------------------------------
# Server Settings
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# ------------------------------------------------------------------------------
# Database Settings (PostgreSQL + pgvector)
# ------------------------------------------------------------------------------
# For local development (docker-compose)
POSTGRES_USER=femtech
POSTGRES_PASSWORD=femtech_dev_password
POSTGRES_DB=femtech_medical
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# For Cloud SQL (production)
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE

# ------------------------------------------------------------------------------
# GCP Settings
# ------------------------------------------------------------------------------
# Create a project at: https://console.cloud.google.com
GCP_PROJECT_ID=your-gcp-project-id

# Storage bucket for medical papers
# Create at: https://console.cloud.google.com/storage
GCP_BUCKET_NAME=femtech-medical-papers

# Path to service account JSON key (for local development)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Required roles: Storage Object Admin, Cloud SQL Client
GCP_CREDENTIALS_PATH=/path/to/service-account-key.json

# Cloud SQL Instance (for production)
# Format: project:region:instance
# GCP_CLOUD_SQL_INSTANCE=your-project:us-central1:femtech-db

# ------------------------------------------------------------------------------
# Azure OpenAI Settings
# ------------------------------------------------------------------------------
# Create at: https://portal.azure.com -> Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Model deployments - create these in Azure OpenAI Studio
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small

# ------------------------------------------------------------------------------
# Azure Document Intelligence Settings
# ------------------------------------------------------------------------------
# Create at: https://portal.azure.com -> Azure AI Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key

# ------------------------------------------------------------------------------
# Langfuse Observability Settings
# ------------------------------------------------------------------------------
# Sign up at: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ------------------------------------------------------------------------------
# Vector Search Settings
# ------------------------------------------------------------------------------
EMBEDDING_DIMENSION=1536
VECTOR_SIMILARITY_TOP_K=10

# ------------------------------------------------------------------------------
# Medical Reasoning Settings (pH thresholds)
# ------------------------------------------------------------------------------
PH_NORMAL_MIN=3.8
PH_NORMAL_MAX=4.5
PH_CONCERNING_THRESHOLD=5.0
